{
  "name": "alrdy-animate",
  "version": "8.0.0-alpha.0",
  "description": "Attribute-driven scroll-animation and interactive-component library. GSAP is loaded externally as a peer dependency.",
  "type": "module",
  "main": "./dist/alrdy-animate.umd.cjs",
  "module": "./dist/alrdy-animate.js",
  "types": "./dist/types/index.d.ts",
  "style": "./dist/alrdy-animate.css",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/alrdy-animate.js",
      "require": "./dist/alrdy-animate.umd.cjs"
    },
    "./features/*": {
      "types": "./dist/types/features/*/index.d.ts",
      "import": "./dist/features/*.js"
    },
    "./jsx": {
      "types": "./dist/types/jsx.d.ts"
    },
    "./style": "./dist/alrdy-animate.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "test": "playwright test",
    "test:update": "playwright test --update-snapshots",
    "docs:dev": "npm --prefix docs run dev",
    "docs:build": "npm --prefix docs run build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "animations",
    "scroll",
    "library",
    "gsap",
    "scroll-animations",
    "web-animations",
    "webflow",
    "nextjs"
  ],
  "author": "Benjamin Brühl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ben-alrdy/alrdy-animate.git"
  },
  "bugs": {
    "url": "https://github.com/ben-alrdy/alrdy-animate/issues"
  },
  "homepage": "https://github.com/ben-alrdy/alrdy-animate#readme",
  "peerDependencies": {
    "gsap": "^3.13.0",
    "lenis": "^1.3.0"
  },
  "peerDependenciesMeta": {
    "lenis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.0",
    "typescript": "^6.0.0",
    "vite": "^7.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
