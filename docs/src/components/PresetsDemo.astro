---
interface Props {
  caption?: string
}

const { caption } = Astro.props
---

<div class="demo-frame" data-demo-frame data-presets-demo>
  {caption && (
    <div class="demo-caption" aria-hidden="true">
      <div class="demo-caption-row">
        <code>{caption}</code>
      </div>
    </div>
  )}
  <slot />
</div>

<script>
  import 'alrdy-animate/style'
</script>

<script>
  import { init } from 'alrdy-animate'

  function ready(): void {
    init({
      debug: true,
      duration: 0.6,
      ease: 'osmo',
      scrollStart: 'top 70%',
      presets: {
        'heading-style-h2': { animate: 'text-fade-up', split: 'lines' },
        'heading-style-h3': { animate: 'text-blur-up', split: 'words' },
        'cta-card': { animate: 'fade-up', duration: '0.4|0.3' },
      },
    })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', ready)
  } else {
    ready()
  }
</script>

<style>
  .demo-frame {
    position: relative;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1rem;
    margin: 1rem 0;
    background: var(--sl-color-bg-nav);
    overflow: clip;
    --sl-content-gap-y: 0;
  }
  .demo-frame :global([data-demo-stage]) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .demo-frame :global([data-spacer]) {
    height: 100px;
  }
  .demo-frame :global(.cta-card) {
    margin: 0 !important;
    padding: 0.85rem 1rem;
    background: var(--sl-color-accent);
    color: var(--sl-color-text-invert, var(--sl-color-white));
    border-radius: 6px;
    font-size: 0.95rem;
    text-align: center;
  }
  .demo-frame :global(.heading-style-h2) {
    margin: 0 !important;
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--sl-color-text);
  }
  .demo-frame :global(.heading-style-h3) {
    margin: 0 !important;
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--sl-color-text);
  }
  .demo-caption {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    z-index: 2;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    max-width: calc(100% - 1rem);
    padding: 0.35rem 0.6rem;
    background: color-mix(in srgb, var(--sl-color-bg, #000) 88%, transparent);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    backdrop-filter: blur(6px);
    font-family: var(--sl-font-system-mono, monospace);
    font-size: 0.72rem;
    line-height: 1.3;
    color: var(--sl-color-gray-2);
  }
  .demo-caption-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem;
  }
  .demo-caption code {
    background: transparent;
    padding: 0;
    font-size: inherit;
    color: var(--sl-color-text);
  }
</style>
