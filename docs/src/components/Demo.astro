---
interface Props {}
---

<div class="demo-frame" data-demo-frame>
  <slot />
</div>

<script>
  import 'alrdy-animate/style'
</script>

<script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>

<script>
  import { init } from 'alrdy-animate'

  function ready(): void {
    init({ debug: true })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', ready)
  } else {
    ready()
  }
</script>

<style>
  .demo-frame {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1rem;
    margin: 1rem 0;
    background: var(--sl-color-bg-nav);
    overflow: hidden;
  }

  .demo-frame :global([data-demo-stage]) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .demo-frame :global([data-spacer]) {
    height: 50vh;
  }

  .demo-frame :global(.demo-card) {
    padding: 2.5rem 2rem;
    background: var(--sl-color-accent);
    color: var(--sl-color-white);
    border-radius: 8px;
    font-weight: 600;
    text-align: center;
    box-shadow: 0 8px 32px hsl(var(--sl-hue-accent) 60% 40% / 0.25);
  }
</style>
