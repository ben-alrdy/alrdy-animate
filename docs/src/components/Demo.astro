---
interface Props {}
---

<div class="demo-frame" data-demo-frame>
  <slot />
</div>

<script>
  import 'alrdy-animate/style'
</script>

<script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/SplitText.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/CustomEase.min.js"></script>

<script>
  import { init } from 'alrdy-animate'

  function ready(): void {
    init({ debug: true, scrollStart: 'top 70%', scrubStart: 'top 90%' })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', ready)
  } else {
    ready()
  }
</script>

<style>
  .demo-frame {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1rem;
    margin: 1rem 0;
    background: var(--sl-color-bg-nav);
    overflow: hidden;
    /* Kill the prose `* + *` sibling margin for everything inside the demo
       frame. The Starlight rule reads `margin-top: var(--sl-content-gap-y)`,
       so zeroing the variable here silences it for demo content. */
    --sl-content-gap-y: 0;
  }

  .demo-frame :global([data-demo-stage]) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Spacers separate demo blocks vertically and give scroll triggers some
     room to engage. Kept small so the demo frame doesn't stretch the
     surrounding content unnecessarily. */
  .demo-frame :global([data-spacer]) {
    height: 100px;
  }

  .demo-frame :global(.demo-card) {
    /* Starlight's prose styles set `* + * { margin-block-start: 16px }` on
       siblings inside .sl-markdown-content. Inside a grid cell that offsets
       cards downward so the first row looks taller than the second. Kill
       the prose sibling margin and any auto-hyphenation. */
    margin: 0 !important;
    padding: 0.85rem 1rem;
    background: var(--sl-color-accent);
    color: var(--sl-color-text-invert, var(--sl-color-white));
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 400;
    text-align: center;
    hyphens: none;
    overflow-wrap: normal;
    word-break: normal;
  }
</style>
